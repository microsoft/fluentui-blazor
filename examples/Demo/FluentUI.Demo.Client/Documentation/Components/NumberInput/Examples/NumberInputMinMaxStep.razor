<FluentStack Orientation="Orientation.Vertical" VerticalGap="10">
    <FluentNumberInput TValue="double"
                       Label="Price"
                       Placeholder="1.0"
                       Step="0.01"
                       Min="0"
                       Max="10"
                       @bind-Value="@price" />

    <FluentNumberInput TValue="int"
                       Label="Items (2 to 50, step 2)"
                       Step="2"
                       Min="2"
                       Max="50"
                       @bind-Value="@items" />

    <FluentNumberInput TValue="decimal"
                       Label="Percentage (0 to 100, step 0.5)"
                       Step="0.5m"
                       Min="0m"
                       Max="100m"
                       @bind-Value="@percentage" />
</FluentStack>

<FluentLabel>Price = @price</FluentLabel>
<FluentLabel>Items = @items</FluentLabel>
<FluentLabel>Percentage = @percentage</FluentLabel>

@code
{
    double price = 1.0;
    int items = 10;
    decimal percentage = 50.0m;
}
