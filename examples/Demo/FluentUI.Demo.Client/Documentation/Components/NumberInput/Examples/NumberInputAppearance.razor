<FluentStack HorizontalGap="20px" Wrap="true">
    <FluentNumberInput TValue="double" Appearance="@TextInputAppearance.Outline" Label="Outline" Placeholder="0.00" @bind-Value="@Value" />
    <FluentNumberInput TValue="double" Appearance="@TextInputAppearance.Underline" Label="Underline" Placeholder="0.00" @bind-Value="@Value" />
    <FluentNumberInput TValue="double" Appearance="@TextInputAppearance.FilledLighter" Label="FilledLighter" Placeholder="0.00" @bind-Value="@Value" />
    <FluentNumberInput TValue="double" Appearance="@TextInputAppearance.FilledDarker" Label="FilledDarker" Placeholder="0.00" @bind-Value="@Value" />
</FluentStack>

<FluentStack HorizontalGap="20px" Wrap="true">
    <FluentNumberInput TValue="double" Size="@TextInputSize.Small" Label="Small" Placeholder="0.00" @bind-Value="@Value" />
    <FluentNumberInput TValue="double" Size="@TextInputSize.Medium" Label="Medium" Placeholder="0.00" @bind-Value="@Value" />
    <FluentNumberInput TValue="double" Size="@TextInputSize.Large" Label="Large" Placeholder="0.00" @bind-Value="@Value" />
</FluentStack>

<FluentLabel>Value = @Value</FluentLabel>

@code
{
    double Value = 0;
}
