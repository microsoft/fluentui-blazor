<FluentNumberInput TValue="double"
                  Label="@($"Value: {Value}")"
                  Step="0.1"
                  Min="0"
                  Max="100"
                  Placeholder="Type a number..."
                  Immediate="true"
                  ImmediateDelay="300"
                  @bind-Value="@Value" />

<FluentLabel>Value = @Value</FluentLabel>

@code
{
    double Value = 0;
}
