@using System.Globalization
<FluentStack HorizontalGap="20px">
    <FluentNumber TValue="int"
                  Culture="@SelectedCulture"
                  Min="0"
                  Max="9999"
                  Step="2"
                  Label="Integer"
                  Placeholder="Number"
                  @bind-Value="@ValueInt" />

    <FluentNumber TValue="double"
                  Culture="@SelectedCulture"
                  Label="Decimal"
                  Placeholder="Number"
                  Step="0.1"
                  @bind-Value="@ValueDouble" />
</FluentStack>

<FluentText>ValueInt = @ValueInt</FluentText>
<FluentText>ValueDouble = @ValueDouble</FluentText>

<FluentStack>
    <FluentSelect Label="Select Culture"
                  Items="@AllCultures"
                  Width="380px"
                  OptionText="@(item => $"{item.DisplayName} [{item.NumberFormat.NumberDecimalDigits} digits, '{item.NumberFormat.NumberDecimalSeparator}' decimal, '{item.NumberFormat.NumberGroupSeparator}' group]")"
                  @bind-Value="@SelectedCulture"
                  @bind-Value:after="@ResetValues" />
</FluentStack>

@code
{
    static CultureInfo[] AllCultures = [
        new FluentNumberCultureInfo(),
        new CultureInfo("fr"),
        new CultureInfo("en"),
        new CultureInfo("de"),
        new CultureInfo("es"),
        new CultureInfo("ja")];

    private CultureInfo SelectedCulture = AllCultures[0];

    int ValueInt = 0;
    double ValueDouble = 0.0;

    void ResetValues()
    {
        ValueInt = 0;
        ValueDouble = 0.0;
    }
}
