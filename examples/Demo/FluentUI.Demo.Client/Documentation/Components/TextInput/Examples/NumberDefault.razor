<FluentStack HorizontalGap="20px">
    <FluentNumber TValue="int"
                  Min="0"
                  Max="999"
                  Label="Integer"
                  Placeholder="Number"
                  @bind-Value="@ValueInt" />

    <FluentNumber TValue="decimal"
                  Label="Decimal"
                  Placeholder="Number"
                  @bind-Value="@ValueDecimal" />
</FluentStack>

<FluentLabel>ValueInt = @ValueInt</FluentLabel>
<FluentLabel>ValueDecimal = @ValueDecimal</FluentLabel>

@code
{
    string ValueInt = "";
    string ValueDecimal = "";
}
