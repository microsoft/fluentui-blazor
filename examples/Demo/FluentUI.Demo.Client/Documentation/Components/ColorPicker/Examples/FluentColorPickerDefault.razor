<FluentStack>
    <FluentSelect Label="Flow Direction"
                  Items=@(Enum.GetValues(typeof(Orientation)).Cast<Orientation>())"
                  @bind-Value="Orientation" />
</FluentStack>

<FluentColorPicker Orientation="Orientation"
                   @bind-SelectedColor="SelectedColor" />

<FluentColorPicker Orientation="Orientation"
                   View="ColorPickerView.ColorWheel"
                   @bind-SelectedColor="SelectedColor" />

<FluentColorPicker Orientation="Orientation"
                   View="ColorPickerView.HsvSquare"
                   @bind-SelectedColor="SelectedColor" />

<div>
    <FluentText>Selected Color: @SelectedColor</FluentText>
</div>

@code
{
    Orientation Orientation = Orientation.Vertical;
    string SelectedColor = "#FFFFFF";
}
