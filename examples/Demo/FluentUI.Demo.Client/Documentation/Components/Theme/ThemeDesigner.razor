@inject IJSRuntime JSRuntime
<h3>ThemeDesigner</h3>

<FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16px">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="10" Width="200px">
        <FluentTextInput Label="Color" Width="150px" Placeholder="Color" @bind-Value="@_color" @bind-Value:after="@PreviewTheme" TextInputType="TextInputType.Color" />
        <p>Selected color in hex: @_color</p>
        <FluentTextInput Label="Hue Torsion" @bind-Value="@_hue" @bind-Value:after="@PreviewTheme" TextInputType="TextInputType.Number" Message="Between -50 and 50" MessageCondition="@FluentFieldCondition.Always"/>
        <FluentTextInput Label="Vibrancy" @bind-Value="@_vibrancy" @bind-Value:after="@PreviewTheme" TextInputType="TextInputType.Number" Message="Between -50 and 50" MessageCondition="@FluentFieldCondition.Always"/>
        <FluentSwitch @bind-Value="@_isDark" @bind-Value:after="@PreviewTheme" Label="Dark" />
        <FluentSwitch @bind-Value="@_isExact" @bind-Value:after="@PreviewTheme" Label="Use exact color" />
        <FluentButton Appearance="ButtonAppearance.Primary" OnClick="@PreviewTheme">Preview Theme</FluentButton>
    </FluentStack>


    <div id="theme-preview" @ref="_themePreviewElement">
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="10">
            <FluentText Typo="Typography.H5">Generated palette</FluentText>
            <div class="palette" style="max-width: 750px;">
                @foreach (var item in _palette)
                {
                    <div class="palette-item" style="background-color: @item.Value ; color: white;">
                        <div class="hex-copy">
                            <span class="palette-item-color">@item.Value</span>
                            <button type="button" class="fui-Button r1f29ykk ___ltdxof0 f1c21dwh f1p3nwhy f11589ue f1q5o8ev f1pdflbu fkfq4zb fjxutwb f1s2uweq fr80ssc f1ukrpxl fecsdlb f139oj5f ft1hn21 fuxngvv fkoldzo fhvnf4x fb6swo4 f1klyf7k f232fm2 f1l983o9 f1nhwcv0 f1gm6xmp fxoo9op f1v3eptx f1i0gk12 fd4bjan f17fgpbq fu97m5z ft85np5 fy9rknc figsok6 fwrc4pm fazmxh f1jt17bm">
                                <span class="fui-Button__icon rywnvv2 ___hix1za0 fe5j1ua fjamq6b f64fuq3 fbaiahx">
                                    <svg color="white" class="fui-Icon-filled ___yt8pzc0 fjseox fez10in f1dd5bof" fill="currentColor" aria-hidden="true" width="1em" height="1em" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M6 4c0-1.1.9-2 2-2h6a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V4ZM4 6a2 2 0 0 1 1-1.73V14.5A2.5 2.5 0 0 0 7.5 17h6.23A2 2 0 0 1 12 18H7.5A3.5 3.5 0 0 1 4 14.5V6Z" fill="currentColor" />
                                    </svg>
                                    <svg color="white" class="fui-Icon-regular ___9ctc0p0 f1w7gpdv fez10in f1dd5bof" fill="currentColor" aria-hidden="true" width="1em" height="1em" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M8 2a2 2 0 0 0-2 2v10c0 1.1.9 2 2 2h6a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8ZM7 4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H8a1 1 0 0 1-1-1V4ZM4 6a2 2 0 0 1 1-1.73V14.5A2.5 2.5 0 0 0 7.5 17h6.23A2 2 0 0 1 12 18H7.5A3.5 3.5 0 0 1 4 14.5V6Z" fill="currentColor" />
                                    </svg>
                                </span>
                            </button>
                        </div>
                        <span class="palette-item-text">@item.Key</span>
                    </div>
                }
            </div>

            <FluentText Typo="Typography.H5">Examples</FluentText>
            <div class="sticker-sheet">
                <div class="sticker-card">
                    <div class="sticker-title">Buttons</div>
                    <FluentStack Orientation="Orientation.Horizontal" Gap="12px" Wrap="true">
                        <FluentButton Appearance="ButtonAppearance.Primary">Primary</FluentButton>
                        <FluentButton Appearance="ButtonAppearance.Outline">Outline</FluentButton>
                        <FluentButton>Default</FluentButton>
                        <FluentButton Disabled="true">Disabled</FluentButton>
                    </FluentStack>
                </div>

                <div class="sticker-card">
                    <div class="sticker-title">Inputs</div>
                    <FluentStack Orientation="Orientation.Vertical" Gap="12px">
                        <FluentTextInput Label="Text" Placeholder="Type here" />
                        <FluentTextInput Label="Number" Value="42" TextInputType="TextInputType.Number" />
                        <FluentCheckbox Value="true" Label="Option 1" />
                        <FluentCheckbox Value="false" Label="Option 2" />
                        <FluentRadioGroup Label="Radio group" @bind-Value="_fruit">
                            <FluentRadio Label="Apple" />
                            <FluentRadio Label="Banana" />
                        </FluentRadioGroup>

                        <FluentSwitch @bind-Value="_switched" Label="Switch" />
                    </FluentStack>
                </div>

                <div class="sticker-card">
                    <div class="sticker-title">Status</div>
                    <FluentStack Orientation="Orientation.Vertical" Gap="12px">
                        <FluentCard>
                            <FluentText Typo="Typography.Body1">Neutral surface</FluentText>
                            <FluentText Typo="Typography.Body2">Foreground and background tokens</FluentText>
                        </FluentCard>
                        <FluentCard Style="background: var(--colorBrandBackground); color: var(--colorNeutralForegroundOnBrand);">
                            <FluentText Typo="Typography.Body1">Brand surface</FluentText>
                            <FluentText Typo="Typography.Body2">Uses brand background tokens</FluentText>
                        </FluentCard>
                    </FluentStack>
                </div>

                <div class="sticker-card">
                    <div class="sticker-title">Progress</div>
                    <FluentStack Orientation="Orientation.Vertical" Gap="12px">

                        <FluentSlider @bind-Value="_slider" Min="0" Max="100" Step="5" Style="width: 350px;" />
                    </FluentStack>
                </div>
            </div>
        </FluentStack>
    </div>
</FluentStack>
@code {
    string? _color = "#0F6CBD";
    string? _hue = "0";
    string? _vibrancy = "0";
    bool _isDark;
    bool _isExact;
    ElementReference _themePreviewElement;

    bool _switched = true;
    double _slider = 35;
    string _fruit = "Banana";


    Dictionary<string, string> _palette = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await PreviewTheme();
        }
    }

    private async Task PreviewTheme()
    {
        double hue = int.TryParse(_hue, out var h) ? h / 100.0 : 0;
        double vibrancy = int.TryParse(_vibrancy, out var v) ? v / 100.0 : 0;

        await JSRuntime.InvokeVoidAsync("Blazor.theme.setBrandThemeToElement", _themePreviewElement, _color, hue, vibrancy, _isDark, _isExact);

        _palette = await JSRuntime.InvokeAsync<Dictionary<string, string>>("Blazor.theme.getCachedRamp");
        StateHasChanged();

    }
}
