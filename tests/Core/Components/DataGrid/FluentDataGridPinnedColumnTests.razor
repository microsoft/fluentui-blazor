@using Xunit
@inherits FluentUITestContext

@code {
    public FluentDataGridPinnedColumnTests()
    {
        JSInterop.Mode = JSRuntimeMode.Loose;

        Services.AddFluentUIComponents();
        Services.AddScoped<IKeyCodeService>(factory => new KeyCodeService());
    }

    // -------------------------------------------------------------------------
    // Default value
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Default_Pin_Is_None()
    {
        // Arrange && Act
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                <ChildContent>
                    <PropertyColumn Property="@(x => x.Name)" Width="100px" />
                </ChildContent>
            </FluentDataGrid>);

        // Assert — every column defaults to Pin = None
        var grid = cut.Instance;
        Assert.All(grid._columns, col => Assert.Equal(DataGridColumnPin.None, col.Pin));
    }

    // -------------------------------------------------------------------------
    // Single pinned-start column: correct CSS class and sticky style
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Start_Has_Sticky_Class_And_Style()
    {
        // Arrange && Act
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                <ChildContent>
                    <PropertyColumn Title="Name" Property="@(x => x.Name)" Width="100px" Pin="DataGridColumnPin.Start" />
                </ChildContent>
            </FluentDataGrid>);

        // Assert — every cell in the column carries col-pinned-start and position:sticky;inset-inline-start:0px
        var cells = cut.FindAll("[col-index='1']");
        Assert.NotEmpty(cells);
        Assert.All(cells, cell =>
        {
            Assert.Contains("col-pinned-start", cell.ClassName);
            Assert.Contains("position: sticky", cell.GetAttribute("style") ?? "");
            Assert.Contains("inset-inline-start: 0px", cell.GetAttribute("style") ?? "");
        });
    }

    // -------------------------------------------------------------------------
    // Single pinned-end column: correct CSS class and sticky style
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_End_Has_Sticky_Class_And_Style()
    {
        // Arrange && Act
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                <ChildContent>
                    <PropertyColumn Title="Name" Property="@(x => x.Name)" Width="80px" Pin="DataGridColumnPin.End" />
                </ChildContent>
            </FluentDataGrid>);

        var cells = cut.FindAll("[col-index='1']");
        Assert.NotEmpty(cells);
        Assert.All(cells, cell =>
        {
            Assert.Contains("col-pinned-end", cell.ClassName);
            Assert.Contains("position: sticky", cell.GetAttribute("style") ?? "");
            Assert.Contains("inset-inline-end: 0px", cell.GetAttribute("style") ?? "");
        });
    }

    [Fact]
    public void FluentDataGrid_PinnedColumn_Header_Uses_Configured_MinWidth()
    {
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()" HeaderCellAsButtonWithMenu="false">
                <ChildContent>
                    <PropertyColumn Title="Name" Property="@(x => x.Name)" Width="120px" MinWidth="150px" Pin="DataGridColumnPin.Start" />
                </ChildContent>
            </FluentDataGrid>);

        var header = cut.Find("th[col-index='1']");

        Assert.Contains("min-width: 150px", header.GetAttribute("style") ?? "");
    }

    // -------------------------------------------------------------------------
    // Two start-pinned columns: cumulative offsets
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Start_Multiple_Cumulative_Offsets()
    {
        // Arrange && Act — col1: 100px, col2: 120px → col1 inset-inline-start:0px, col2 inset-inline-start:100px
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                <ChildContent>
                    <PropertyColumn Title="Id"   Property="@(x => x.Id)"   Width="100px" Pin="DataGridColumnPin.Start" />
                    <PropertyColumn Title="Name" Property="@(x => x.Name)" Width="120px" Pin="DataGridColumnPin.Start" />
                </ChildContent>
            </FluentDataGrid>);

        Assert.All(cut.FindAll("[col-index='1']"), cell =>
            Assert.Contains("inset-inline-start: 0px", cell.GetAttribute("style") ?? ""));

        Assert.All(cut.FindAll("[col-index='2']"), cell =>
            Assert.Contains("inset-inline-start: 100px", cell.GetAttribute("style") ?? ""));
    }

    // -------------------------------------------------------------------------
    // Two end-pinned columns: cumulative offsets
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_End_Multiple_Cumulative_Offsets()
    {
        // col1 (normal 1fr) | col2: 80px end-pinned | col3: 60px end-pinned
        // col3 (rightmost) → inset-inline-end:0px  |  col2 → inset-inline-end:60px
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                <ChildContent>
                    <PropertyColumn Title="Name"   Property="@(x => x.Name)" />
                    <PropertyColumn Title="City"   Property="@(x => x.City)"   Width="80px"  Pin="DataGridColumnPin.End" />
                    <PropertyColumn Title="Action" Property="@(x => x.Action)" Width="60px"  Pin="DataGridColumnPin.End" />
                </ChildContent>
            </FluentDataGrid>);

        // col3 is index 3 — rightmost end-pinned → inset-inline-end: 0px
        Assert.All(cut.FindAll("[col-index='3']"), cell =>
            Assert.Contains("inset-inline-end: 0px", cell.GetAttribute("style") ?? ""));

        // col2 is index 2 — next-to-last end-pinned → inset-inline-end: 60px (width of col3)
        Assert.All(cut.FindAll("[col-index='2']"), cell =>
            Assert.Contains("inset-inline-end: 60px", cell.GetAttribute("style") ?? ""));
    }

    // -------------------------------------------------------------------------
    // Pinned column without Width throws
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Without_Width_Throws()
    {
        Assert.Throws<ArgumentException>(() =>
        {
            Render<FluentDataGrid<Customer>>(
                @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                    <ChildContent>
                        <PropertyColumn Title="Name" Property="@(x => x.Name)" Pin="DataGridColumnPin.Start" />
                    </ChildContent>
                </FluentDataGrid>);
        });
    }

    // -------------------------------------------------------------------------
    // Pinned column with non-px Width throws
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_With_NonPixel_Width_Throws()
    {
        Assert.Throws<ArgumentException>(() =>
        {
            Render<FluentDataGrid<Customer>>(
                @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                    <ChildContent>
                        <PropertyColumn Title="Name" Property="@(x => x.Name)" Width="1fr" Pin="DataGridColumnPin.Start" />
                    </ChildContent>
                </FluentDataGrid>);
        });
    }

    // -------------------------------------------------------------------------
    // Ordering validation: isolated start-pinned column (not at the start) throws
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Start_Not_At_Start_Throws()
    {
        // col1 is unpinned, col2 is start-pinned → invalid
        Assert.Throws<ArgumentException>(() =>
        {
            Render<FluentDataGrid<Customer>>(
                @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                    <ChildContent>
                        <PropertyColumn Title="Name"   Property="@(x => x.Name)" />
                        <PropertyColumn Title="City"   Property="@(x => x.City)"   Width="120px" Pin="DataGridColumnPin.Start" />
                    </ChildContent>
                </FluentDataGrid>);
        });
    }

    // -------------------------------------------------------------------------
    // Ordering validation: start-pinned columns split by a normal column throws
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Start_NonContiguous_Throws()
    {
        // col1 start-pinned, col2 normal, col3 start-pinned → not contiguous
        Assert.Throws<ArgumentException>(() =>
        {
            Render<FluentDataGrid<Customer>>(
                @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                    <ChildContent>
                        <PropertyColumn Title="Id"     Property="@(x => x.Id)"     Width="60px"  Pin="DataGridColumnPin.Start" />
                        <PropertyColumn Title="Name"   Property="@(x => x.Name)" />
                        <PropertyColumn Title="City"   Property="@(x => x.City)"   Width="120px" Pin="DataGridColumnPin.Start" />
                    </ChildContent>
                </FluentDataGrid>);
        });
    }

    // -------------------------------------------------------------------------
    // Ordering validation: isolated end-pinned column (not at the end) throws
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_End_Not_At_End_Throws()
    {
        // col1 end-pinned, col2 normal → invalid
        Assert.Throws<ArgumentException>(() =>
        {
            Render<FluentDataGrid<Customer>>(
                @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                    <ChildContent>
                        <PropertyColumn Title="Name"   Property="@(x => x.Name)"   Width="120px" Pin="DataGridColumnPin.End" />
                        <PropertyColumn Title="City"   Property="@(x => x.City)" />
                    </ChildContent>
                </FluentDataGrid>);
        });
    }

    // -------------------------------------------------------------------------
    // Ordering validation: end-pinned columns split by a normal column throws
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_End_NonContiguous_Throws()
    {
        // col1 normal, col2 end-pinned, col3 normal, col4 end-pinned → not contiguous
        Assert.Throws<ArgumentException>(() =>
        {
            Render<FluentDataGrid<Customer>>(
                @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                    <ChildContent>
                        <PropertyColumn Title="Name"   Property="@(x => x.Name)" />
                        <PropertyColumn Title="City"   Property="@(x => x.City)"   Width="80px"  Pin="DataGridColumnPin.End" />
                        <PropertyColumn Title="Zip"    Property="@(x => x.Zip)" />
                        <PropertyColumn Title="Action" Property="@(x => x.Action)" Width="60px"  Pin="DataGridColumnPin.End" />
                    </ChildContent>
                </FluentDataGrid>);
        });
    }

    // -------------------------------------------------------------------------
    // Valid mixed layout: start-pinned + normal + end-pinned
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_StartAndEnd_Valid_Layout()
    {
        // Should not throw; verify offsets are correct
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                <ChildContent>
                    <PropertyColumn Title="Id"     Property="@(x => x.Id)"     Width="50px"  Pin="DataGridColumnPin.Start" />
                    <PropertyColumn Title="Name"   Property="@(x => x.Name)"   Width="150px" Pin="DataGridColumnPin.Start" />
                    <PropertyColumn Title="City"   Property="@(x => x.City)" />
                    <PropertyColumn Title="Action" Property="@(x => x.Action)" Width="100px" Pin="DataGridColumnPin.End" />
                </ChildContent>
            </FluentDataGrid>);

        // col1 (Id)   start-pinned → inset-inline-start: 0px
        Assert.All(cut.FindAll("[col-index='1']"), c =>
            Assert.Contains("inset-inline-start: 0px", c.GetAttribute("style") ?? ""));

        // col2 (Name) start-pinned → inset-inline-start: 50px
        Assert.All(cut.FindAll("[col-index='2']"), c =>
            Assert.Contains("inset-inline-start: 50px", c.GetAttribute("style") ?? ""));

        // col3 (City) not pinned → no sticky style
        Assert.All(cut.FindAll("[col-index='3']"), c =>
            Assert.DoesNotContain("position: sticky", c.GetAttribute("style") ?? ""));

        // col4 (Action) end-pinned → inset-inline-end: 0px
        Assert.All(cut.FindAll("[col-index='4']"), c =>
            Assert.Contains("inset-inline-end: 0px", c.GetAttribute("style") ?? ""));
    }

    // -------------------------------------------------------------------------
    // Snapshot test
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Snapshot()
    {
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                <ChildContent>
                    <PropertyColumn Title="Id"   Property="@(x => x.Id)"   Width="50px"  Pin="DataGridColumnPin.Start" />
                    <PropertyColumn Title="Name" Property="@(x => x.Name)" Width="150px" Pin="DataGridColumnPin.Start" />
                    <PropertyColumn Title="City" Property="@(x => x.City)" />
                    <PropertyColumn Title="Action" Property="@(x => x.Action)" Width="100px" Pin="DataGridColumnPin.End" />
                </ChildContent>
            </FluentDataGrid>);

        Assert.All(cut.FindAll("th"), header =>
            Assert.DoesNotContain("z-index: 5", header.GetAttribute("style") ?? ""));

        cut.Verify();
    }

    // -------------------------------------------------------------------------
    // Helper data
    // -------------------------------------------------------------------------

    private IEnumerable<Customer> GetCustomers()
    {
        yield return new Customer(1, "Denis Voituron", "Brussels", "BE-1000", "Edit");
        yield return new Customer(2, "Vincent Baaij",  "Amsterdam", "NL-1011", "Edit");
        yield return new Customer(3, "Bill Gates",     "Medina",    "US-98039", "Edit");
    }

    private record Customer(int Id, string Name, string City, string Zip, string Action);
}
