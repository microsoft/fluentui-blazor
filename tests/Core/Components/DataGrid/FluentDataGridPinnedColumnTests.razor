@using Xunit
@inherits FluentUITestContext

@code {
    public FluentDataGridPinnedColumnTests()
    {
        JSInterop.Mode = JSRuntimeMode.Loose;

        Services.AddFluentUIComponents();
        Services.AddScoped<IKeyCodeService>(factory => new KeyCodeService());
    }

    // -------------------------------------------------------------------------
    // Default value
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Default_Pin_Is_None()
    {
        // Arrange && Act
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                <ChildContent>
                    <PropertyColumn Property="@(x => x.Name)" Width="100px" />
                </ChildContent>
            </FluentDataGrid>);

        // Assert — every column defaults to Pin = None
        var grid = cut.Instance;
        Assert.All(grid._columns, col => Assert.Equal(DataGridColumnPin.None, col.Pin));
    }

    // -------------------------------------------------------------------------
    // Single pinned-left column: correct CSS class and sticky style
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Left_Has_Sticky_Class_And_Style()
    {
        // Arrange && Act
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                <ChildContent>
                    <PropertyColumn Title="Name" Property="@(x => x.Name)" Width="100px" Pin="DataGridColumnPin.Left" />
                </ChildContent>
            </FluentDataGrid>);

        // Assert — every cell in the column carries col-pinned-left and position:sticky;left:0px
        var cells = cut.FindAll("[col-index='1']");
        Assert.NotEmpty(cells);
        Assert.All(cells, cell =>
        {
            Assert.Contains("col-pinned-left", cell.ClassName);
            Assert.Contains("position: sticky", cell.GetAttribute("style") ?? "");
            Assert.Contains("left: 0px", cell.GetAttribute("style") ?? "");
        });
    }

    // -------------------------------------------------------------------------
    // Single pinned-right column: correct CSS class and sticky style
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Right_Has_Sticky_Class_And_Style()
    {
        // Arrange && Act
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                <ChildContent>
                    <PropertyColumn Title="Name" Property="@(x => x.Name)" Width="80px" Pin="DataGridColumnPin.Right" />
                </ChildContent>
            </FluentDataGrid>);

        var cells = cut.FindAll("[col-index='1']");
        Assert.NotEmpty(cells);
        Assert.All(cells, cell =>
        {
            Assert.Contains("col-pinned-right", cell.ClassName);
            Assert.Contains("position: sticky", cell.GetAttribute("style") ?? "");
            Assert.Contains("right: 0px", cell.GetAttribute("style") ?? "");
        });
    }

    // -------------------------------------------------------------------------
    // Two left-pinned columns: cumulative offsets
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Left_Multiple_Cumulative_Offsets()
    {
        // Arrange && Act — col1: 100px, col2: 120px → col1 left:0px, col2 left:100px
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                <ChildContent>
                    <PropertyColumn Title="Id"   Property="@(x => x.Id)"   Width="100px" Pin="DataGridColumnPin.Left" />
                    <PropertyColumn Title="Name" Property="@(x => x.Name)" Width="120px" Pin="DataGridColumnPin.Left" />
                </ChildContent>
            </FluentDataGrid>);

        Assert.All(cut.FindAll("[col-index='1']"), cell =>
            Assert.Contains("left: 0px", cell.GetAttribute("style") ?? ""));

        Assert.All(cut.FindAll("[col-index='2']"), cell =>
            Assert.Contains("left: 100px", cell.GetAttribute("style") ?? ""));
    }

    // -------------------------------------------------------------------------
    // Two right-pinned columns: cumulative offsets
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Right_Multiple_Cumulative_Offsets()
    {
        // col1 (normal 1fr) | col2: 80px right-pinned | col3: 60px right-pinned
        // col3 (rightmost) → right:0px  |  col2 → right:60px
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                <ChildContent>
                    <PropertyColumn Title="Name"   Property="@(x => x.Name)" />
                    <PropertyColumn Title="City"   Property="@(x => x.City)"   Width="80px"  Pin="DataGridColumnPin.Right" />
                    <PropertyColumn Title="Action" Property="@(x => x.Action)" Width="60px"  Pin="DataGridColumnPin.Right" />
                </ChildContent>
            </FluentDataGrid>);

        // col3 is index 3 — rightmost right-pinned → right: 0px
        Assert.All(cut.FindAll("[col-index='3']"), cell =>
            Assert.Contains("right: 0px", cell.GetAttribute("style") ?? ""));

        // col2 is index 2 — next-to-last right-pinned → right: 60px (width of col3)
        Assert.All(cut.FindAll("[col-index='2']"), cell =>
            Assert.Contains("right: 60px", cell.GetAttribute("style") ?? ""));
    }

    // -------------------------------------------------------------------------
    // Pinned column without Width throws
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Without_Width_Throws()
    {
        Assert.Throws<ArgumentException>(() =>
        {
            Render<FluentDataGrid<Customer>>(
                @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                    <ChildContent>
                        <PropertyColumn Title="Name" Property="@(x => x.Name)" Pin="DataGridColumnPin.Left" />
                    </ChildContent>
                </FluentDataGrid>);
        });
    }

    // -------------------------------------------------------------------------
    // Pinned column with non-px Width throws
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_With_NonPixel_Width_Throws()
    {
        Assert.Throws<ArgumentException>(() =>
        {
            Render<FluentDataGrid<Customer>>(
                @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                    <ChildContent>
                        <PropertyColumn Title="Name" Property="@(x => x.Name)" Width="1fr" Pin="DataGridColumnPin.Left" />
                    </ChildContent>
                </FluentDataGrid>);
        });
    }

    // -------------------------------------------------------------------------
    // Ordering validation: isolated left-pinned column (not at the start) throws
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Left_Not_At_Start_Throws()
    {
        // col1 is unpinned, col2 is left-pinned → invalid
        Assert.Throws<ArgumentException>(() =>
        {
            Render<FluentDataGrid<Customer>>(
                @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                    <ChildContent>
                        <PropertyColumn Title="Name"   Property="@(x => x.Name)" />
                        <PropertyColumn Title="City"   Property="@(x => x.City)"   Width="120px" Pin="DataGridColumnPin.Left" />
                    </ChildContent>
                </FluentDataGrid>);
        });
    }

    // -------------------------------------------------------------------------
    // Ordering validation: left-pinned columns split by a normal column throws
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Left_NonContiguous_Throws()
    {
        // col1 left-pinned, col2 normal, col3 left-pinned → not contiguous
        Assert.Throws<ArgumentException>(() =>
        {
            Render<FluentDataGrid<Customer>>(
                @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                    <ChildContent>
                        <PropertyColumn Title="Id"     Property="@(x => x.Id)"     Width="60px"  Pin="DataGridColumnPin.Left" />
                        <PropertyColumn Title="Name"   Property="@(x => x.Name)" />
                        <PropertyColumn Title="City"   Property="@(x => x.City)"   Width="120px" Pin="DataGridColumnPin.Left" />
                    </ChildContent>
                </FluentDataGrid>);
        });
    }

    // -------------------------------------------------------------------------
    // Ordering validation: isolated right-pinned column (not at the end) throws
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Right_Not_At_End_Throws()
    {
        // col1 right-pinned, col2 normal → invalid
        Assert.Throws<ArgumentException>(() =>
        {
            Render<FluentDataGrid<Customer>>(
                @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                    <ChildContent>
                        <PropertyColumn Title="Name"   Property="@(x => x.Name)"   Width="120px" Pin="DataGridColumnPin.Right" />
                        <PropertyColumn Title="City"   Property="@(x => x.City)" />
                    </ChildContent>
                </FluentDataGrid>);
        });
    }

    // -------------------------------------------------------------------------
    // Ordering validation: right-pinned columns split by a normal column throws
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Right_NonContiguous_Throws()
    {
        // col1 normal, col2 right-pinned, col3 normal, col4 right-pinned → not contiguous
        Assert.Throws<ArgumentException>(() =>
        {
            Render<FluentDataGrid<Customer>>(
                @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                    <ChildContent>
                        <PropertyColumn Title="Name"   Property="@(x => x.Name)" />
                        <PropertyColumn Title="City"   Property="@(x => x.City)"   Width="80px"  Pin="DataGridColumnPin.Right" />
                        <PropertyColumn Title="Zip"    Property="@(x => x.Zip)" />
                        <PropertyColumn Title="Action" Property="@(x => x.Action)" Width="60px"  Pin="DataGridColumnPin.Right" />
                    </ChildContent>
                </FluentDataGrid>);
        });
    }

    // -------------------------------------------------------------------------
    // Valid mixed layout: left-pinned + normal + right-pinned
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_LeftAndRight_Valid_Layout()
    {
        // Should not throw; verify offsets are correct
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                <ChildContent>
                    <PropertyColumn Title="Id"     Property="@(x => x.Id)"     Width="50px"  Pin="DataGridColumnPin.Left" />
                    <PropertyColumn Title="Name"   Property="@(x => x.Name)"   Width="150px" Pin="DataGridColumnPin.Left" />
                    <PropertyColumn Title="City"   Property="@(x => x.City)" />
                    <PropertyColumn Title="Action" Property="@(x => x.Action)" Width="100px" Pin="DataGridColumnPin.Right" />
                </ChildContent>
            </FluentDataGrid>);

        // col1 (Id)   left-pinned → left: 0px
        Assert.All(cut.FindAll("[col-index='1']"), c =>
            Assert.Contains("left: 0px", c.GetAttribute("style") ?? ""));

        // col2 (Name) left-pinned → left: 50px
        Assert.All(cut.FindAll("[col-index='2']"), c =>
            Assert.Contains("left: 50px", c.GetAttribute("style") ?? ""));

        // col3 (City) not pinned → no sticky style
        Assert.All(cut.FindAll("[col-index='3']"), c =>
            Assert.DoesNotContain("position: sticky", c.GetAttribute("style") ?? ""));

        // col4 (Action) right-pinned → right: 0px
        Assert.All(cut.FindAll("[col-index='4']"), c =>
            Assert.Contains("right: 0px", c.GetAttribute("style") ?? ""));
    }

    // -------------------------------------------------------------------------
    // Snapshot test
    // -------------------------------------------------------------------------

    [Fact]
    public void FluentDataGrid_PinnedColumn_Snapshot()
    {
        var cut = Render<FluentDataGrid<Customer>>(
            @<FluentDataGrid Items="@GetCustomers().AsQueryable()">
                <ChildContent>
                    <PropertyColumn Title="Id"   Property="@(x => x.Id)"   Width="50px"  Pin="DataGridColumnPin.Left" />
                    <PropertyColumn Title="Name" Property="@(x => x.Name)" Width="150px" Pin="DataGridColumnPin.Left" />
                    <PropertyColumn Title="City" Property="@(x => x.City)" />
                    <PropertyColumn Title="Action" Property="@(x => x.Action)" Width="100px" Pin="DataGridColumnPin.Right" />
                </ChildContent>
            </FluentDataGrid>);

        Assert.All(cut.FindAll("th"), header =>
            Assert.DoesNotContain("z-index: 5", header.GetAttribute("style") ?? ""));

        cut.Verify();
    }

    // -------------------------------------------------------------------------
    // Helper data
    // -------------------------------------------------------------------------

    private IEnumerable<Customer> GetCustomers()
    {
        yield return new Customer(1, "Denis Voituron", "Brussels", "BE-1000", "Edit");
        yield return new Customer(2, "Vincent Baaij",  "Amsterdam", "NL-1011", "Edit");
        yield return new Customer(3, "Bill Gates",     "Medina",    "US-98039", "Edit");
    }

    private record Customer(int Id, string Name, string City, string Zip, string Action);
}
