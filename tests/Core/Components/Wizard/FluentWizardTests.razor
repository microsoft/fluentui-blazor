				<Steps>
					<FluentWizardStep Label="Step 1">Content 1</FluentWizardStep>
					<FluentWizardStep Label="Step 2">Content 2</FluentWizardStep>
					<FluentWizardStep Label="Step 3">Content 3</FluentWizardStep>
				</Steps>
			</FluentWizard>);

		// Assert
		cut.Verify();
	}

