    [Fact]
    public void FluentAutocomplete_SingleSelect_SecondItemReplacesFirst()
    {
        string? SelectedItem = null;

        // Arrange
        var cut = Render(@<FluentAutocomplete Id="my-list"
                                TOption="string"
                                TValue="string"
                                Multiple="false"
                                @bind-SelectedItem="@SelectedItem"
                                OnOptionsSearch="@OnOptionsSearch" />);

        // Act - Open the dropdown to display all options
        cut.Find("fluent-text-input").Click();

        var options = cut.FindAll("fluent-option");
        var id1 = options[0].GetAttribute("id"); // "Eight"
        var id2 = options[1].GetAttribute("id"); // "Five"

        // Select the first item ("Eight")
        cut.Find(".fluent-listbox")
           .TriggerEvent("onlistchange", new DropdownEventArgs { SelectedOptions = id1 });

        // Assert - "Eight" is displayed in the StartTemplate
        var badge = cut.Find("span.fluent-badge[alone]");
        Assert.Equal("Eight", badge.GetAttribute("title"));

        // Act - Open dropdown again and select the second item ("Five")
        cut.Find("fluent-text-input").Click();

        options = cut.FindAll("fluent-option");
        id2 = options[1].GetAttribute("id"); // "Five" (re-read after re-render)

        cut.Find(".fluent-listbox")
           .TriggerEvent("onlistchange", new DropdownEventArgs { SelectedOptions = id2 });

        // Assert - "Five" replaced "Eight" in the StartTemplate
        badge = cut.Find("span.fluent-badge[alone]");
        Assert.Equal("Five", badge.GetAttribute("title"));

        // Only one badge should be present
        var badges = cut.FindAll("span.fluent-badge");
        Assert.Single(badges);
        Assert.Equal("Five", SelectedItem);
    }

