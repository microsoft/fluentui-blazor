    [Fact(Timeout = TEST_TIMEOUT)]
    public async Task FluentToast_MarginPadding()
    {
        // Arrange
        var toastOptions = new ToastOptions()
        {
            Class = "my-class",
            Style = "color: red;",
            Margin = "10px",
            Padding = "20px",
            Body = "Spacing body",
        };

        // Act
        _ = ToastService.ShowToastAsync(toastOptions);

        // Don't wait for the toast to be closed
        await Task.CompletedTask;

        // Assert: StyleValue includes margin and padding
        Assert.Contains("margin", toastOptions.StyleValue);
        Assert.Contains("10px", toastOptions.StyleValue);
        Assert.Contains("padding", toastOptions.StyleValue);
        Assert.Contains("20px", toastOptions.StyleValue);
        Assert.Contains("color: red;", toastOptions.StyleValue);
    }

