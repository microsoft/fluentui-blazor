    [Fact]
    public void FluentNumber_Culture_Default()
    {
        // Arrange and Act
        var cut = Render(@<FluentNumberInput TValue="double" Label="number" Value="1234.56" />);
        var instance = cut.FindComponent<FluentNumberInput<double>>().Instance;

        // Assert - Default culture is FluentNumberCultureInfo
        Assert.IsType<FluentNumberInputCultureInfo>(instance.Culture);
        Assert.Equal(2, instance.Culture.NumberFormat.NumberDecimalDigits);
        Assert.Equal("", instance.Culture.NumberFormat.NumberGroupSeparator);

        // The decimal separator comes from CurrentCulture
        var expectedSeparator = System.Globalization.CultureInfo.CurrentCulture.NumberFormat.NumberDecimalSeparator;
        Assert.Equal(expectedSeparator, instance.Culture.NumberFormat.NumberDecimalSeparator);

        var input = cut.Find("fluent-text-input");
        Assert.Equal($"1234{expectedSeparator}56", input.GetAttribute("value"));
    }

    [Fact]
    public void FluentNumber_Culture_US()
    {
        // Arrange
        var usCulture = new System.Globalization.CultureInfo("en-US");

        // Act
        var cut = Render(@<FluentNumberInput TValue="double" Label="number" Value="1234.56" Culture="@usCulture" />);
        var instance = cut.FindComponent<FluentNumberInput<double>>().Instance;

        // Assert
        Assert.Equal("en-US", instance.Culture.Name);
        Assert.Equal(".", instance.Culture.NumberFormat.NumberDecimalSeparator);
        Assert.Equal(",", instance.Culture.NumberFormat.NumberGroupSeparator);

        var input = cut.Find("fluent-text-input");
        var value = input.GetAttribute("value");
        Assert.StartsWith("1,234.56", value);
    }

