    [Fact]
    public void FluentNumber_Culture_Default()
    {
        // Arrange and Act
        var cut = Render(@<FluentNumber TValue="double" Label="number" Value="1234.56" />);
        var instance = cut.FindComponent<FluentNumber<double>>().Instance;

        // Assert - Default culture is FluentNumberCultureInfo
        Assert.IsType<FluentNumberCultureInfo>(instance.Culture);
        Assert.Equal(2, instance.Culture.NumberFormat.NumberDecimalDigits);
        Assert.Equal("", instance.Culture.NumberFormat.NumberGroupSeparator);

        // The decimal separator comes from CurrentCulture
        var expectedSeparator = System.Globalization.CultureInfo.CurrentCulture.NumberFormat.NumberDecimalSeparator;
        Assert.Equal(expectedSeparator, instance.Culture.NumberFormat.NumberDecimalSeparator);

        var input = cut.Find("fluent-text-input");
        Assert.Equal($"1234{expectedSeparator}56", input.GetAttribute("value"));
    }

    [Fact]
    public void FluentNumber_Culture_US()
    {
        // Arrange
        var usCulture = new System.Globalization.CultureInfo("en-US");

        // Act
        var cut = Render(@<FluentNumber TValue="double" Label="number" Value="1234.56" Culture="@usCulture" />);
        var instance = cut.FindComponent<FluentNumber<double>>().Instance;

        // Assert
        Assert.Equal("en-US", instance.Culture.Name);
        Assert.Equal(".", instance.Culture.NumberFormat.NumberDecimalSeparator);
        Assert.Equal(",", instance.Culture.NumberFormat.NumberGroupSeparator);

        var input = cut.Find("fluent-text-input");
        var value = input.GetAttribute("value");
        Assert.StartsWith("1,234.56", value);
    }

    [Fact]
    public void FluentNumber_Culture_FR()
    {
        // Arrange
        var frCulture = new System.Globalization.CultureInfo("fr-FR");

        // Act
        var cut = Render(@<FluentNumber TValue="double" Label="number" Value="1234.56" Culture="@frCulture" />);
        var instance = cut.FindComponent<FluentNumber<double>>().Instance;

        // Assert
        Assert.Equal("fr-FR", instance.Culture.Name);
        Assert.Equal(",", instance.Culture.NumberFormat.NumberDecimalSeparator);

        var input = cut.Find("fluent-text-input");
        var value = input.GetAttribute("value");
        Assert.Contains("1", value);
        Assert.Contains("234,56", value);
    }

    [Fact]
    public void FluentNumber_Culture_FluentNumberCultureInfo()
    {
        // Arrange
        var fluentCulture = new FluentNumberCultureInfo(3, ".", ",");

        // Act
        var cut = Render(@<FluentNumber TValue="double" Label="number" Value="1234.56" Culture="@fluentCulture" />);
        var instance = cut.FindComponent<FluentNumber<double>>().Instance;

        // Assert
        Assert.IsType<FluentNumberCultureInfo>(instance.Culture);
        Assert.Equal(3, instance.Culture.NumberFormat.NumberDecimalDigits);
        Assert.Equal(".", instance.Culture.NumberFormat.NumberDecimalSeparator);
        Assert.Equal(",", instance.Culture.NumberFormat.NumberGroupSeparator);

        var input = cut.Find("fluent-text-input");
        Assert.Equal("1,234.560", input.GetAttribute("value"));
    }

