@namespace Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.FluentUI.AspNetCore.Components.Extensions
@inherits FluentListBase<TOption, TValue>
@typeparam TOption
@typeparam TValue

<CascadingValue Value="GetCurrentContext()"
                Name="ListContext"
                TValue="InternalListContext<TValue>"
                IsFixed="true">
    <CascadingValue Value="(InternalListContext)GetCurrentContext()"
                    Name="ListContextBase"
                    TValue="InternalListContext"
                    IsFixed="true">

        <FluentTextInput Id="@Id"
                         Immediate="true"
                         ImmediateDelay="@ImmediateDelay"
                         Style="@StyleValue"
                         Class="@ClassValue"
                         auto-complete="true"
                         Width="@Width"
                         AutoComplete="false"
                         @onkeydown="@OnTextInputKeyDownAsync"
                         @onclick="@(e => DisplayFilteredOptionsAsync(showWhenInputIsEmpty: true))"
                         @bind-Value="@_textInput"
                         @bind-Value:after="@DisplayFilteredOptionsAsync">
            @* Selected items *@
            <StartTemplate>
                <div style="@($"{(string.IsNullOrEmpty(MaxAutoHeight) ? "" : $"max-height: {MaxAutoHeight};")}")">
                    @* Show selected items as badges with an "x" button to remove them. This is shown when the listbox is closed, when it's open the selected items are highlighted in the listbox and we don't show the badges in the input. *@
                    @if (_internalSelectedItems is not null)
                    {
                        @foreach (var item in _internalSelectedItems)
                        {
                            <span class="fluent-badge"
                                  title="@GetOptionText(item)"
                                  auto-complete="true">
                                <span>@GetOptionText(item)</span>
                                <FluentIcon Value="@BadgeCloseIcon"
                                            Focusable="true"
                                            OnClick="@(e => RemoveSelectedItemAsync(item))"
                                            OnClickStopPropagation="true"
                                            Width="12px" />
                            </span>
                        }
                    }
                </div>
            </StartTemplate>

            @* Waiting spinner *@
            <EndTemplate>
                @if (ShowProgressIndicator && _inProgress)
                {
                    <FluentSpinner Size="SpinnerSize.Tiny" />
                }
                else
                {
                    if (_internalSelectedItems.Any())
                    {
                        <FluentIcon Value="@ClearIcon" 
                                    Focusable="true"
                                    OnClick="@ClearSelectionAsync"
                                    OnClickStopPropagation="true" />
                    }
                    else
                    {
                        <FluentIcon Value="@SearchIcon" 
                                    Focusable="true"
                                    OnClick="@SwitchOptionsPopupAsync"
                                    OnClickStopPropagation="true" />
                    }
                }
            </EndTemplate>
        </FluentTextInput>

        <FluentPopover AnchorId="@Id"
                       @bind-Opened="@_isOpen"
                       @bind-Opened:after="OnOptionsPopupClosedAsync">

            @if (ShowProgressIndicator)
            {
                <FluentProgressBar Thickness="ProgressThickness.Large" Visible="@_inProgress" />
            }

            <FluentListbox auto-complete="true"
                           TValue="TValue"
                           TOption="TOption"
                           Multiple="true"
                           OptionText="@OptionText"
                           OptionValue="@OptionValue"
                           Items="@_internalFilteredItems"
                           SelectedItems="@_internalSelectedItems"
                           SelectedItemsChanged="@InternalSelectedItemsChangedHandlerAsync" />
        </FluentPopover>

    </CascadingValue>
</CascadingValue>
