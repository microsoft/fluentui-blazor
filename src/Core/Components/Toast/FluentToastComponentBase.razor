@namespace Microsoft.FluentUI.AspNetCore.Components
@inherits FluentComponentBase
@using Microsoft.FluentUI.AspNetCore.Components.Extensions
<fluent-toast-b id="@Owner!.Id"
                class="@Owner.ClassValue"
                style="@Owner.StyleValue"
                opened="@(Owner.Opened ? "true" : "false")"
                timeout="@Owner.Timeout"
                position="@Owner.Position.ToAttributeValue()"
                intent="@Owner.Intent.ToAttributeValue()"
                politeness="@Owner.Politeness.ToAttributeValue()"
                pause-on-hover="@(Owner.PauseOnHover ? "true" : null)"
                pause-on-window-blur="@(Owner.PauseOnWindowBlur ? "true" : null)"
                vertical-offset="@Owner.VerticalOffset"
                horizontal-offset="@Owner.HorizontalOffset"
                role="listitem"
                aria-labelledby="@($"{Owner.Id}-title")"
                aria-describedby="@($"{Owner.Id}-body")"
                @attributes="@Owner.AdditionalAttributes"
                @ondialogtoggle="@Owner.OnToggleAsync"
                @ondialogbeforetoggle="@Owner.OnToggleAsync">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
</fluent-toast-b>
