@namespace Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.FluentUI.AspNetCore.Components.Extensions
@inherits FluentComponentBase

<div id="@Id"
     class="@ClassValue"
     style="@StyleValue"
     view="@View.ToAttributeValue()"
     orientation="@Orientation.ToAttributeValue()"
     @attributes="@AdditionalAttributes">

    @switch (View)
    {
        case ColorPickerView.SwatchPalette:

            @foreach (var color in DefaultColors)
            {
                <div style="background-color: @color;"
                     selected="@IsSelectedColor(color)"
                     @onclick="@(async () => await ColorSelectHandlerAsync(color))">
                    @if (IsSelectedColor(color))
                    {
                        <div part="indicator" />
                    }
                </div>
            }

            break;

        case ColorPickerView.ColorWheel:

            <svg viewBox="@WheelViewBox">
                @{
                    var ci = 0;
                    for (var row = 0; row < WheelRowSizes.Length; row++)
                    {
                        var count = WheelRowSizes[row];
                        var cy = WheelPadding + HexSize + row * HexYSpacing;
                        for (var col = 0; col < count; col++)
                        {
                            var cx = WheelCenterX + (col - (count - 1) / 2.0) * HexWidth;
                            var hc = WheelColors[ci++];
                            var isSelected = IsSelectedColor(hc);
                            <polygon points="@HexPointsAttr(cx, cy)"
                                     fill="@hc"
                                     stroke="@hc"
                                     stroke-width="1"
                                     selected="@(isSelected ? true : null)"
                                     @onclick="@(async () => await ColorSelectHandlerAsync(hc))" />
                            @if (isSelected)
                            {
                                <circle cx="@Inv(cx)" cy="@Inv(cy)" r="@Inv(HexSize / 3)"
                                        part="indicator" />
                            }
                        }
                    }
                }
            </svg>

            break;

        case ColorPickerView.HsvSquare:

            <div part="square">
                <div part="canvas"
                     style="@HsvSquareStyle">
                    <div part="gradient-white"></div>
                    <div part="gradient-black"></div>
                    <div part="indicator"
                         style="left: @HsvIndicatorLeft; top: @HsvIndicatorTop;"></div>
                </div>
            </div>
            <div part="hue-bar">
                <div part="hue-indicator"
                     style="top: @HsvHueIndicatorTop;"></div>
            </div>

            break;
    }
</div>